{
	"name": "dating-site-api",
	"type": "module",
	"main": "src/index.ts",
	"scripts": {
		"build": "tsdown",
		"check-types": "tsc -b",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
		"dev": "wrangler dev",
		"deploy:worker": "pnpm run build && wrangler deploy"
	},
	"dependencies": {
		"@JustHookUps/auth": "workspace:*",
		"@JustHookUps/db": "workspace:*",
		"@JustHookUps/env": "workspace:*",
		"better-auth": "catalog:",
		"dotenv": "catalog:",
		"drizzle-orm": "^0.45.2",
		"hono": "^4.8.2",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@JustHookUps/config": "workspace:*",
		"@cloudflare/workers-types": "catalog:",
		"@types/node": "catalog:",
		"alchemy": "catalog:",
		"tsdown": "^0.16.5",
		"typescript": "catalog:",
		"wrangler": "^4.77.0"
	}
}
