# Copy to `apps/server/.env` (gitignored). See docs/ENVIRONMENT.md for full reference.
# Validate: `pnpm env:check` from repo root.

# Neon Postgres (Worker / app — pooled URL is OK)
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Optional: direct (non-pooled) URL for `pnpm db:migrate` / Drizzle CLI only.
# If unset, drizzle.config rewrites common pooled URLs (`-pooler` host, pgbouncer=true).
# Copy from Neon → Connection details → "Direct connection".
# DATABASE_URL_MIGRATE=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Credentialed CORS — must match the browser origin exactly (scheme + host + port).
# Flutter web: copy the URL from the address bar, e.g. http://localhost:53210
# Multiple origins: comma-separated (no spaces), e.g. Flutter web + another tool:
# CORS_ORIGIN=http://localhost:53210,http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# Better Auth — public URL of THIS API as clients reach it
BETTER_AUTH_URL=http://127.0.0.1:8787

# Better Auth — min 32 chars (e.g. openssl rand -hex 32)
BETTER_AUTH_SECRET=

# --- Wrangler only ---
# Put DATABASE_URL, BETTER_AUTH_SECRET, and any overrides in `apps/server/.dev.vars`
# (same variable names). R2 binding MEDIA_BUCKET comes from wrangler.toml, not .env.

# --- Alchemy (`pnpm dev:alchemy`) ---
# Run `alchemy login` or set CLOUDFLARE_API_TOKEN in your shell / packages/alchemy/.env
